# Database Configuration
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres_secure_password
POSTGRES_DB=knowledge_platform
POSTGRES_HOST=db
POSTGRES_PORT=5432
DATABASE_URL=postgresql+pg8000://postgres:postgres_secure_password@db:5432/knowledge_platform

# JWT Configuration
JWT_SECRET_KEY=generate_a_very_long_secure_random_key_for_access_tokens
JWT_REFRESH_SECRET_KEY=generate_another_long_secure_random_key_for_refresh_tokens
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# OpenAI API Key (Required for multi-agent logic and vector embeddings)
OPENAI_API_KEY=your_openai_api_key_here

# Vector Store Config
CHROMA_PERSIST_DIRECTORY=./chromadb_store

# Platform & Security Settings
RATE_LIMIT_PER_MINUTE=100
FRONTEND_URL=http://localhost:5173
BACKEND_URL=http://localhost:8000
ENVIRONMENT=development
