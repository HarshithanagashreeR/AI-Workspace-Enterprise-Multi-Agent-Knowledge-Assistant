# Root .gitignore for AI Enterprise Multi-Agent Knowledge Assistant

# OS specific files
.DS_Store
Thumbs.db

# Editor configurations
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Log files
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Environment variable files
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Python global ignores
__pycache__/
*.pyc
*.pyo
*.pyd
.pytest_cache/
.poetry.lock
poetry.lock
Pipfile.lock

# Backend specific ignores
backend/venv/
backend/venv312/
backend/.env
backend/*.db
backend/chromadb_store/
backend/storage/

# Frontend specific ignores
frontend/node_modules/
frontend/dist/
frontend/dist-ssr/
frontend/*.local
